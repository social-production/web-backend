# Database
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/social_production

# JWT
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRE_MINUTES=60

# Message encryption (Fernet key)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MESSAGE_ENCRYPTION_KEY=replace-with-a-fernet-key

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS — comma-separated origins, or * to allow all
CORS_ORIGINS=http://localhost:5173
