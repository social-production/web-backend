# Database
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/social_production

# JWT
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-only-change-me
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Message encryption (Fernet key)
# Generate your own for local dev: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Do not reuse this placeholder if you share a database with others.
MESSAGE_ENCRYPTION_KEY=IoR_TjHO_mc373uQePi0GDzCouould4_1Sx6TB4ChD8=

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=2
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=2
REDIS_MAX_CONNECTIONS=50
REDIS_CACHE_TTL_SECONDS=3600

# CORS — comma-separated origins. Production must use explicit origins.
CORS_ORIGINS=http://localhost:5173

# GitHub feedback — required for POST /feedback (create a fine-grained PAT with Issues: write)
GITHUB_TOKEN=
GITHUB_REPO=social-production/web
