# Production environment template — copy to .env.production and fill in strong secrets.
APP_ENV=production

# Required secrets (generate unique values for each deployment)
JWT_SECRET=
MESSAGE_ENCRYPTION_KEY=
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# Database (overridden by docker-compose.prod.yml service wiring)
POSTGRES_DB=social_production
POSTGRES_USER=postgres
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@postgres:5432/social_production

# Redis (overridden by docker-compose.prod.yml)
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=2
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=2
REDIS_MAX_CONNECTIONS=50
REDIS_CACHE_TTL_SECONDS=3600

# Comma-separated explicit origins — never use * in production
CORS_ORIGINS=https://your-domain.example

# Optional GitHub feedback integration
GITHUB_TOKEN=
GITHUB_REPO=social-production/web

# Host port published for the API container (reverse proxy may bind elsewhere)
API_PORT=8000
